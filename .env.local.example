# Javelina Environment Variables

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Express API Backend
NEXT_PUBLIC_API_URL=http://localhost:3001

# Admin Panel JWT Secret (must match ADMIN_JWT_SECRET in Express backend)
# Generate with: openssl rand -hex 32
ADMIN_JWT_SECRET=your_admin_jwt_secret

# ============================================
# Support Chat System Configuration
# ============================================

# Mock Mode Toggle
# Set to 'true' to use simulated responses for development/testing without backend
# Set to 'false' or remove to use real API endpoints and integrations
NEXT_PUBLIC_MOCK_SUPPORT_API=true

# Freshdesk Integration
# Domain: Your Freshdesk subdomain (e.g., 'javelina' for javelina.freshdesk.com)
# Required when NEXT_PUBLIC_FRESHDESK_ENABLED=true
NEXT_PUBLIC_FRESHDESK_DOMAIN=your_subdomain

# API Key: Generate from Freshdesk Profile Settings > API Key section
# This is server-side only and should never be exposed to the client
# Required when NEXT_PUBLIC_FRESHDESK_ENABLED=true
FRESHDESK_API_KEY=your_freshdesk_api_key

# Enable/disable real Freshdesk API calls
# Set to 'true' to create actual tickets in Freshdesk
# Set to 'false' for development mode with mock responses
NEXT_PUBLIC_FRESHDESK_ENABLED=false

# LLM Configuration for AI-Powered Support
# Provider: The LLM service to use (e.g., 'openai', 'anthropic')
# Required when AI-powered responses are enabled
NEXT_PUBLIC_LLM_PROVIDER=openai

# API Key: Your LLM provider's API key (server-side only, keep secret!)
# OpenAI: Get from https://platform.openai.com/api-keys
# Anthropic: Get from https://console.anthropic.com/settings/keys
# Required for AI-powered chat responses
LLM_API_KEY=your_llm_api_key

# Model: The specific model to use for chat responses
# OpenAI examples: 'gpt-4', 'gpt-3.5-turbo'
# Anthropic examples: 'claude-3-opus', 'claude-3-sonnet'
# Optional - defaults to provider's recommended model
NEXT_PUBLIC_LLM_MODEL=gpt-4

# Feature Flags
# Enable AI-powered chat responses (requires LLM_API_KEY and NEXT_PUBLIC_LLM_PROVIDER)
NEXT_PUBLIC_SUPPORT_AI_ENABLED=false

# Enable automatic ticket creation in Freshdesk for unresolved chats
# Requires NEXT_PUBLIC_FRESHDESK_ENABLED=true and valid Freshdesk credentials
NEXT_PUBLIC_SUPPORT_AUTO_TICKET_CREATION=false

# Enable chat analytics and logging (recommended for production)
NEXT_PUBLIC_SUPPORT_ANALYTICS_ENABLED=true

# Maximum number of messages to retain in chat history
# Optional - defaults to 50 if not specified
NEXT_PUBLIC_SUPPORT_MAX_CHAT_HISTORY=50

# ============================================

# Stripe (for billing/payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_key
