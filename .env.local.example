# Javelina Frontend Environment Variables
#
# Don't edit .env.local directly — edit .env.dev / .env.production and run
# `npm run env:dev` or `npm run env:prod` to switch (copies the file over).
# See README.md "Environment Variables" for what each var does.

# --- Required ---

# Express backend API (javelina-backend)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# --- Server-side only (never NEXT_PUBLIC) ---

# Stripe secret key, used by server-side routes
STRIPE_SECRET_KEY=sk_test_...

# Admin Panel JWT secret — must match ADMIN_JWT_SECRET in javelina-backend
# Generate with: openssl rand -hex 32
ADMIN_JWT_SECRET=your_admin_jwt_secret

# Supabase service-role key (staff admin portal server code only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Optional ---

# Canonical site URL (falls back to VERCEL_URL / localhost)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# LaunchDarkly feature flags
# NEXT_PUBLIC_LAUNCHDARKLY_CLIENT_ID=

# hCaptcha on auth forms
# NEXT_PUBLIC_SUPABASE_CAPTCHA_ENABLED=false
# NEXT_PUBLIC_HCAPTCHA_SITE_KEY_DEV=
# NEXT_PUBLIC_HCAPTCHA_SITE_KEY_PROD=

# OpenSRS domain-registration storefront
# NEXT_PUBLIC_OPENSRS_STOREFRONT_URL=

# Freshdesk support-ticket integration
# NEXT_PUBLIC_FRESHDESK_ENABLED=false
# NEXT_PUBLIC_FRESHDESK_DOMAIN=your_subdomain
# FRESHDESK_API_KEY=your_freshdesk_api_key

# Inactivity logout tuning (milliseconds)
# NEXT_PUBLIC_IDLE_TIMEOUT_MS=
# NEXT_PUBLIC_IDLE_WARNING_MS=
# NEXT_PUBLIC_ADMIN_IDLE_TIMEOUT_MS=

# Stripe price IDs per plan (used by pricing/checkout)
# NEXT_PUBLIC_STRIPE_PRICE_STARTER_MONTHLY=
# NEXT_PUBLIC_STRIPE_PRICE_BASIC_MONTHLY=
# NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=
# NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE_MONTHLY=
